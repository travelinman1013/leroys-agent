;; Hermes gateway sandbox profile — Phase 4 R4 (Layer 2: kernel MACF via Seatbelt)
;;
;; Goal: clamp filesystem to needed paths; clamp network to LM Studio +
;; HTTPS outbound. User-specific (hardcoded paths for Maxwell's machine);
;; do not ship to other users without a path audit.
;;
;; Must be kept in sync with security.safe_roots in ~/.hermes/config.yaml
;; (the R3 inline path-jail is the app-level mirror of this profile).
;;
;; Deploy:
;;   cp scripts/sandbox/hermes.sb ~/.hermes/hermes.sb
;;   scripts/sandbox/validate-profile.sh
;;   # then wrap launchd plist (see plan)
;;
;; Iterate:
;;   sandbox-exec -f ~/.hermes/hermes.sb hermes chat
;;   # add allow rules for any denial that surfaces

(version 1)
(deny default)
(debug deny)

;; --- macOS runtime plumbing ---
;; Import Apple's stock system.sb so dyld closure mapping, framework
;; loading, and the long tail of XNU plumbing that Python+venv need just
;; works. This is a private interface (Apple may change its contents
;; between macOS releases) — validate-profile.sh re-runs the syntax probe
;; before each deploy so we catch breakage early. If a future macOS
;; removes this file, replace with explicit (allow file-map-executable
;; ...) + (allow mach-lookup ...) rules; the bare-minimum equivalent
;; turned out to be more than 20 lines and still missed dyld closure
;; reads on darwin 25.x.
(import "/System/Library/Sandbox/Profiles/system.sb")

;; Process + IPC essentials still spelled explicitly so they're auditable
;; even if system.sb's defaults shift.
(allow process-fork)
(allow process-exec)
(allow signal (target self))
(allow sysctl-read)
(allow mach-lookup)        ;; macOS IPC (XPC, libdispatch)
(allow iokit-open)         ;; libdispatch / CoreFoundation
(allow file-ioctl)
(allow file-read-metadata) ;; stat(), fstat()
(allow system-socket)      ;; DNS resolution, generic socket ops

;; --- File reads: broad system paths + explicit user paths ---
(allow file-read*
  (subpath "/System")
  (subpath "/Library")
  (subpath "/usr")
  (subpath "/bin")
  (subpath "/sbin")
  (subpath "/opt/homebrew")
  (subpath "/var/folders")
  (subpath "/private/var/folders")
  (subpath "/private/etc")                               ;; resolv.conf, hosts, ssl
  (subpath "/etc")
  (subpath "/Users/maxwell/os-apps/hermes/venv")         ;; Python runtime
  (subpath "/Users/maxwell/os-apps/hermes")              ;; source tree
  (subpath "/Users/maxwell/.hermes")                     ;; agent state
  (subpath "/Users/maxwell/Projects")                    ;; scan target
  (subpath "/Users/maxwell/brain")                       ;; vault (symlink → LETSGO/MaxVault)
  (subpath "/Users/maxwell/LETSGO/MaxVault")             ;; vault realpath target
  (subpath "/Users/maxwell/.cache")                      ;; hf, npm, ms-playwright browser binaries
  (subpath "/Users/maxwell/.npm")                        ;; npx execution cache (includes _npx/)
  (subpath "/Users/maxwell/.local/state/hermes")         ;; gateway locks (discord-bot-token, etc.)
  (subpath "/Users/maxwell/.claude")                     ;; Claude Code auth, config, plugins (Phase 11 CC dispatch)
  (subpath "/Users/maxwell/.claude-mem")                 ;; claude-mem ChromaDB (CC plugin dependency)
  (subpath "/Users/maxwell/.bun")                        ;; Bun runtime (CC spawns bun workers for plugins)
  (subpath "/Users/maxwell/.local/bin")                  ;; uv, uvx (CC spawns chroma-mcp via uv)
  (literal "/Users/maxwell/Library/LaunchAgents/ai.hermes.gateway.plist"))

;; --- Hard deny: credentials. Overrides the allow above by ordering. ---
(deny file-read*
  (subpath "/Users/maxwell/.ssh")
  (literal "/Users/maxwell/.hermes/.env"))

;; --- File writes: state, logs, temp ---
(allow file-write*
  (subpath "/Users/maxwell/.hermes")
  (subpath "/Users/maxwell/.claude")                     ;; Claude Code session state, cache (Phase 11 CC dispatch)
  (subpath "/Users/maxwell/.claude-mem")                 ;; claude-mem ChromaDB writes
  (subpath "/Users/maxwell/.local/state/hermes")         ;; gateway locks
  (subpath "/Users/maxwell/Projects")
  (subpath "/Users/maxwell/brain")                       ;; vault writes (Phase 6 R1)
  (subpath "/Users/maxwell/LETSGO/MaxVault")             ;; vault realpath target
  (subpath "/Users/maxwell/.npm")                        ;; npx cache — needed for GitHub MCP startup (npm EPERM masquerades as "root-owned files")
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath "/var/folders")
  (subpath "/private/var/folders"))
(deny file-write*
  (literal "/Users/maxwell/.hermes/.env")                ;; .env is read-only even to hermes
  ;; config.yaml writes are now allowed — guarded by CONFIG_MUTATION_ALLOWLIST
  ;; + CONFIG_MUTATION_DENYLIST in hermes_cli/config.py (Python-level gate)
  (literal "/Users/maxwell/.hermes/hermes.sb"))          ;; sandbox profile — prevent self-weakening on restart

;; --- Network outbound ---
;; SBPL syntax notes (verified empirically against macOS 25.4):
;;   (remote ip "host:port")  → host MUST be "*" or "localhost"; explicit
;;                              127.0.0.1 is rejected at parse time. AND
;;                              "*" with a numeric port appears to PARSE
;;                              but not actually MATCH outbound TCP, so
;;                              connections silently time out.
;;   (remote tcp "host:port") → the canonical form Apple's own profiles
;;                              use (see bluetoothuserd.sb, cloudpaird.sb).
;;                              Use this for any non-localhost destination.
;;   (remote udp "host:port") → UDP equivalent.
;; If you change these rules, test with `scripts/sandbox/hermes-gateway-sandboxed`
;; and verify Discord ACTUALLY connects (not just slash command sync — that
;; uses HTTP REST and may work even when the WebSocket gateway can't).
(allow network-outbound
  (remote tcp "localhost:1234")      ;; LLM inference (llama-server / LM Studio)
  (remote tcp "localhost:9222")      ;; Chrome DevTools Protocol (browser tool)
  (remote tcp "localhost:4317")      ;; OpenTelemetry OTLP gRPC (R4 — opt-in)
  (remote tcp "localhost:4318")      ;; OpenTelemetry OTLP HTTP (R4 — opt-in)
  (remote tcp "localhost:6006")      ;; Arize Phoenix UI (R4 — opt-in)
  (remote tcp "localhost:8642")      ;; Hermes dashboard API (R2/R3)
  (remote tcp "localhost:7878")      ;; Radarr API (mediamax)
  (remote tcp "localhost:8989")      ;; Sonarr API (mediamax)
  (remote tcp "localhost:6500")      ;; RDTClient API (mediamax)
  (remote tcp "*:443")              ;; HTTPS — Discord, GitHub, HuggingFace, etc.
  (remote tcp "*:80")               ;; HTTP — direct URL fetches
  (remote tcp "*:53")               ;; DNS over TCP (rare but supported)
  (remote udp "*:53"))              ;; DNS over UDP (default)

;; --- Network bind + inbound: OAuth, API server (R2 :8642), WhatsApp bridge ---
;; Three rules are needed for a TCP listener to actually work:
;;   - (allow network-bind ...)     covers bind()
;;   - (allow network-inbound ...)  covers listen() + accept()
;;   - (allow network* ...)         catches any darwin-specific op we missed
;;
;; Symptom if network-inbound is missing: bind() succeeds, listen() fails
;; with EPERM → aiohttp.TCPSite.start() raises "[Errno 1] Operation not
;; permitted". Discovered during R2 dashboard deploy 2026-04-10.
;;
;; Also: use (local tcp ...) NOT (local ip ...). The ip form parses
;; without error but does NOT match bind/listen on TCP sockets, same
;; way (remote ip ...) fails to match outbound TCP. Seatbelt rejects IP
;; literals in this position — "host must be * or localhost".
(allow network-bind
  (local ip "localhost:*")            ;; legacy UDP compat
  (local tcp "localhost:*")
  (local udp "localhost:*"))
(allow network-inbound
  (local ip "localhost:*")
  (local tcp "localhost:*")
  (local udp "localhost:*"))

;; --- AF_UNIX for the code-execution RPC socket and other unix sockets ---
;; The code-execution RPC creates /tmp/hermes_rpc_<uuid>.sock, covered by
;; the (subpath "/tmp") file rules above. Add the network rules:
(allow network-outbound (remote unix-socket))
(allow network-bind (local unix-socket))

;; --- Iteration log (append entries here as new denials surface) ---
;; Format: ;; YYYY-MM-DD: added <rule> because <symptom> in <context>
;; (Empty until first run.)
